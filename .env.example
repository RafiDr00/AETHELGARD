# Aethelgard Environment Configuration
# Copy this to .env and fill in real values

# --- Core Platform ---
APP_ENV=production
AETHELGARD_API_KEY=your_secret_api_key_here
REDIS_URL=redis://localhost:6379
PORT=8000
LOG_LEVEL=INFO

# --- UI (Browser Settings) ---
AETHELGARD_CORS_ORIGINS=http://localhost:8000,https://rafidr00.github.io

# --- AI / LLM (Required if using OpenAI) ---
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.1

# --- Infrastructure Roles ---
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# --- Sandbox Execution ---
SANDBOX_IMAGE=aethelgard-sandbox:v1
SANDBOX_TIMEOUT=30
SANDBOX_NETWORK_DISABLED=true
