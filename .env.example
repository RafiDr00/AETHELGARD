# ============================================
# Aethelgard v2 — Environment Configuration
# ============================================

# --- Application ---
APP_NAME=aethelgard-v2
APP_ENV=development
APP_VERSION=2.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Redis (Event Bus) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_STREAM_MAX_LEN=10000

# --- LLM Configuration ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096

# --- Vector Store ---
FAISS_INDEX_PATH=./data/faiss_index
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Docker Sandbox ---
SANDBOX_IMAGE=aethelgard-sandbox:latest
SANDBOX_TIMEOUT=30
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_NETWORK_DISABLED=true

# --- Kubernetes ---
KUBE_CONFIG_PATH=~/.kube/config
KUBE_NAMESPACE=aethelgard
KUBE_CONTEXT=default

# --- AWS (Cloud Simulation) ---
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET=aethelgard-artifacts

# --- Metrics ---
METRICS_RETENTION_DAYS=90
ENGINEER_HOURLY_COST=95.0
METRICS_EXPORT_INTERVAL=60

# --- Agent Configuration ---
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT=120
RISK_THRESHOLD_AUTO_DEPLOY=0.3
RISK_THRESHOLD_SUPERVISED=0.7
