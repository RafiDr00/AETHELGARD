# ────────────────────────────────────────────
# Aethelgard — Docker build context exclusions
# ────────────────────────────────────────────
# Keep this file strict: every MB excluded here is an MB that doesn't get
# hashed, transferred to the daemon, and potentially baked into the image.

# ── Secrets (CRITICAL — must never enter the image) ─────────────────────────
.env
.env.*
!.env.example

# ── Version control ──────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Documentation & markdown ─────────────────────────────────────────────────
docs/
*.md
!README.md

# ── Development / research code not needed at runtime ────────────────────────
experiments/
scripts/
tools/

# ── Tests ────────────────────────────────────────────────────────────────────
tests/
.pytest_cache/
.coveragerc
.coverage
htmlcov/

# ── Frontend (built artifact served by nginx; source not needed in API image) ─
ui/
frontend/
# Redundant but explicit — node_modules can be enormous
node_modules/

# ── Infrastructure / deployment config (not needed inside the container) ─────
infra/
deployment/
.github/

# ── Dashboard (separate service; excluded from API image) ────────────────────
dashboard/

# ── Runtime data and logs (written at runtime, not baked in) ─────────────────
data/
logs/
*.log

# ── Python caches and build artifacts ────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.mypy_cache/
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── CI / audit scratch files ─────────────────────────────────────────────────
.audit_*.txt
.pytest_*.txt
.pytest_rc*.txt

# ── Editor and OS noise ───────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
